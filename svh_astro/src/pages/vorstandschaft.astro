---
// src/pages/vorstandschaft.astro
import Layout from '../layouts/Layout.astro';
---
<Layout title="Vorstandschaft – SV Hockenheim e.V.">

<main class="main-wrap">
  <div class="breadcrumb"><a href="/Vereinswebseite/">Home</a><span class="sep">/</span><a href="/Vereinswebseite/verein">Der Verein</a><span class="sep">/</span>Vorstandschaft</div>
  <div class="section-head">
    <div class="section-tag">Führung</div>
    <h2>Die Vorstandschaft</h2>
  </div>
  <div class="badge">Geschäftsführender Vorstand</div>
  <div class="person-grid" id="pgVorstand"></div>
  <div class="badge" style="margin-top:24px">Erweiterte Vorstandschaft</div>
  <div class="person-grid" id="pgErweiterter"></div>
</main>
</Layout>
