---
// src/pages/training.astro
import Layout from '../layouts/Layout.astro';
---
<Layout title="Training – SV Hockenheim e.V.">

<main class="main-wrap">
  <div class="breadcrumb"><a href="/Vereinswebseite/">Home</a><span class="sep">/</span>Training</div>
  <div class="section-head">
    <div class="section-tag">Sport</div>
    <h2>Training beim SVH</h2>
    <p>Strukturiertes Training für alle Altersgruppen – Mo bis Fr im Aquadrom und Lehrschwimmbecken.</p>
  </div>
  <div class="wk-cards">
    <div class="wk-card" onclick="location.href='/Vereinswebseite/jugend'"><div class="wk-icon">🧒</div><h3>Jugend</h3><p>6–20 Jahre · Technik, Kondition und Wettkampf</p></div>
    <div class="wk-card" onclick="location.href='/Vereinswebseite/masters'"><div class="wk-icon">🏅</div><h3>Masters</h3><p>Ab 20 Jahren · Wettkampfsport für Erwachsene</p></div>
    <div class="wk-card" onclick="location.href='/Vereinswebseite/trainingszeiten'"><div class="wk-icon">🕐</div><h3>Trainingszeiten</h3><p>Mo–Fr · Aquadrom &amp; Lehrschwimmbecken</p></div>
    <div class="wk-card" onclick="location.href='/Vereinswebseite/trainer'"><div class="wk-icon">👨‍🏫</div><h3>Unsere Trainer</h3><p>Engagierte Trainer mit Lizenz und Erfahrung</p></div>
    <div class="wk-card" onclick="location.href='/Vereinswebseite/trainingsstaetten'"><div class="wk-icon">🏊</div><h3>Trainingsstätten</h3><p>Aquadrom &amp; Lehrschwimmbecken Hockenheim</p></div>
  </div>
</main>
</Layout>
