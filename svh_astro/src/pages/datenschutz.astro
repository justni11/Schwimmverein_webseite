<Layout title="Datenschutz – SV Hockenheim e.V.">
<main class="main-wrap">
  <div class="breadcrumb"><a href="/Vereinswebseite/">Home</a><span class="sep">/</span>Datenschutz</div>
  <div class="section-head"><h2>Datenschutz</h2></div>
  <div class="white-card" style="max-width:600px">
