---
// src/pages/index.astro
// Haupt-SPA: Alle Seiten-Divs sind hier. JavaScript übernimmt das Routing.
import Layout from '../layouts/Layout.astro';
---
<Layout title="SV Hockenheim e.V.">

<!-- Mobile Drawer -->
<div class="mobile-drawer" id="mobileDrawer">
  <div class="mob-item"><div class="mob-top" onclick="mobNav('home')">Home</div></div>
  <div class="mob-item">
    <div class="mob-top" onclick="toggleMobSub('msub-news')">News <span class="arr">▾</span></div>
    <div class="mob-sub" id="msub-news">
      <a onclick="mobNav('news')">Alle Berichte</a>
      <a onclick="mobArticle('dossenheim2026')">Dossenheim 2026</a>
      <a onclick="mobArticle('hoggicup2026')">Hoggi Cup 2026</a>
      <a onclick="mobArticle('heddesheim2026')">Heddesheim 2026</a>
      <a onclick="mobArticle('bruehlmasters2026')">Masters Brühl 2026</a>
      <a onclick="mobArticle('vereinsfeier2025')">Vereinsfeier 2025</a>
      <a onclick="mobArticle('neptuncup2025')">Neptun Cup 2025</a>
    </div>
  </div>
  <div class="mob-item">
    <div class="mob-top" onclick="toggleMobSub('msub-verein')">Der Verein <span class="arr">▾</span></div>
    <div class="mob-sub" id="msub-verein">
      <a onclick="mobNav('vorstandschaft')">Die Vorstandschaft</a>
      <a onclick="mobNav('historie')">Historie</a>
      <a onclick="mobNav('termine')">Termine</a>
      <a onclick="mobNav('beitragsordnung')">Beitragsordnung</a>
      <a onclick="mobNav('jugendordnung')">Jugendordnung</a>
    </div>
  </div>
  <div class="mob-item">
    <div class="mob-top" onclick="toggleMobSub('msub-training')">Training <span class="arr">▾</span></div>
    <div class="mob-sub" id="msub-training">
      <a onclick="mobNav('jugend')">Jugend</a>
      <a onclick="mobNav('masters')">Masters</a>
      <a onclick="mobNav('trainingszeiten')">Trainingszeiten</a>
      <a onclick="mobNav('trainer')">Unsere Trainer</a>
      <a onclick="mobNav('trainingsstaetten')">Trainingsstätten</a>
    </div>
  </div>
  <div class="mob-item">
    <div class="mob-top" onclick="toggleMobSub('msub-kurse')">Schwimmkurse <span class="arr">▾</span></div>
    <div class="mob-sub" id="msub-kurse">
      <a onclick="mobNav('kurse')">Informationen</a>
      <a onclick="mobNav('kurstrainer')">Kurstrainer</a>
      <a onclick="mobNav('einzelstunden')">Einzelstunden</a>
    </div>
  </div>
  <div class="mob-item"><div class="mob-top" onclick="mobNav('wettkampf')">Wettkampf</div></div>
  <div class="mob-item">
    <div class="mob-top" onclick="toggleMobSub('msub-sonst')">Sonstiges <span class="arr">▾</span></div>
    <div class="mob-sub" id="msub-sonst">
      <a onclick="mobNav('datenschutz')">Datenschutz</a>
      <a onclick="mobNav('impressum')">Impressum</a>
      <a onclick="closeMobileMenu();openAdminLogin()" style="color:rgba(255,255,255,.4);font-size:12px">⚙ Admin Panel</a>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════
     HOME
══════════════════════════════════════ -->
<div class="page active" id="page-home">

  <!-- ── HERO ── -->
  <div class="hero" id="heroSection">
    <div class="hero-grid"></div>
    <div id="heroBgPh" style="display:none;position:absolute;top:10px;right:10px;z-index:5;background:rgba(0,0,0,.45);border-radius:8px;flex-direction:row;align-items:center;gap:6px;padding:6px 12px;cursor:pointer;backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.1)">
      <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="rgba(255,255,255,.5)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg>
      <span style="font-size:11px;color:rgba(255,255,255,.45)">Hintergrundbild</span>
      <input type="file" accept="image/*" style="position:absolute;inset:0;opacity:0;cursor:pointer" onchange="uploadHeroBg(this)"/>
    </div>
    <div id="heroBgOverlay" style="display:none;position:absolute;inset:0;z-index:1;background:linear-gradient(90deg,rgba(4,12,5,.82) 0%,rgba(4,12,5,.65) 35%,rgba(4,12,5,.2) 65%,rgba(4,12,5,.0) 100%);pointer-events:none"></div>
    <img id="heroBgImg" style="position:absolute;inset:0;width:100%;height:100%;object-fit:contain;object-position:center;opacity:1;display:none;transition:filter .3s"/>
    <div class="hero-content">
      <div class="hero-eyebrow">Schwimmverein Hockenheim · Seit 1967</div>
      <h1>Wir sind der<br/><span class="accent-line">SV Hockenheim</span></h1>
      <p>Schwimmen, Gemeinschaft und Erfolge seit 1967. Über 330 Mitglieder – vom Anfänger bis zum Meister.</p>
      <div class="hero-btns">
        <button class="btn-primary" onclick="showPage('verein')">Mehr über uns</button>
        <button class="btn-ghost" onclick="showPage('kurse')">Schwimmkurse</button>
      </div>
      <div class="hero-stats">
        <div class="hero-stat"><div class="num">330+</div><div class="lbl">Mitglieder</div></div>
        <div class="hero-stat"><div class="num">1967</div><div class="lbl">Gegründet</div></div>
        <div class="hero-stat"><div class="num">5×</div><div class="lbl">Wochentage Training</div></div>
      </div>
    </div>
  </div>

  <!-- Wave -->
  <div class="wave-divider">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="height:60px">
      <path d="M0,0 C360,60 1080,0 1440,60 L1440,0 L0,0 Z" fill="var(--bg)"/>
    </svg>
  </div>

  <div class="main-wrap">

    <!-- Intro Strip -->
    <div class="intro-strip">
      <div>
        <h2>Wir stellen uns vor…</h2>
        <p>Der Schwimmverein Hockenheim e.V. wurde am 16.06.1967 mit 31 Mitgliedern gegründet. In der Zwischenzeit konnten Schwimmer/innen beachtliche Platzierungen und Meistertitel bei Kreis-, Bezirks-, Badischen Jahrgangs-, Baden-Württembergischen und Deutschen Master-Meisterschaften erzielen.</p>
        <button class="btn-ghost" style="font-size:13px;padding:10px 22px" onclick="showPage('verein')">Vereinsgeschichte lesen</button>
      </div>
      <div class="intro-stat">
        <div class="num">330+</div>
        <div class="lbl">Mitglieder</div>
      </div>
    </div>

    <!-- ── BILDKARUSSELL ── -->
    <div class="carousel-wrap" style="margin-bottom:48px">
      <div class="carousel-track" id="heroSlider">
        <div class="carousel-slide" id="hs0">
          <div class="carousel-slide-label" style="display:block"><h2>Vereinsmeisterschaften 2025</h2><p>Früh aufgestanden, stark geschwommen</p></div>
        </div>
        <div class="carousel-slide" id="hs1">
          <div class="carousel-slide-label" style="display:block"><h2>Hoggi Cup 2026</h2><p>Unser vereinseigener Nachwuchswettbewerb</p></div>
        </div>
        <div class="carousel-slide" id="hs2">
          <div class="carousel-slide-label" style="display:block"><h2>Trainingslager 2025</h2><p>Freudenstadt im Schwarzwald</p></div>
        </div>
        <div class="carousel-slide" id="hs3">
          <div class="carousel-slide-label" style="display:block"><h2>Wandertag 2025</h2><p>Gemeinschaft auch abseits des Wassers</p></div>
        </div>
      </div>
      <button class="c-btn prev" onclick="changeSlide(-1)">&#8249;</button>
      <button class="c-btn next" onclick="changeSlide(1)">&#8250;</button>
      <div class="c-dots" id="sDots">
        <button class="c-dot active" onclick="goSlide(0)"></button>
        <button class="c-dot" onclick="goSlide(1)"></button>
        <button class="c-dot" onclick="goSlide(2)"></button>
        <button class="c-dot" onclick="goSlide(3)"></button>
      </div>
    </div>

    <!-- News -->
    <div class="section-head">
      <div class="section-tag">Aktuelles</div>
      <h2>Neueste Berichte</h2>
      <p>Wettkämpfe, Vereinsleben und besondere Momente aus dem SVH.</p>
    </div>
    <div class="news-grid" id="homeNewsGrid"></div>
    <div style="text-align:center;margin-bottom:56px">
      <button class="btn-primary" onclick="showPage('news')">Alle Berichte anzeigen</button>
    </div>

    <!-- Kurse Teaser -->
    <div class="section-head">
      <div class="section-tag">Mitmachen</div>
      <h2>Schwimmkurse in Hockenheim</h2>
    </div>
    <div class="white-card">
      <p style="color:var(--text2);line-height:1.8;margin-bottom:20px;font-size:15px">Seit Januar 2017 bieten wir neue Schwimmkurse für alle Kinder ab fünf Jahren an. Wir haben ein neues Konzept eingeführt, welches individuell auf jedes Kind abgestimmt ist und mit dem wir euch noch gezielter fördern können.</p>
      <button class="btn-primary" onclick="showPage('kurse')">mehr lesen</button>
    </div>

  </div><!-- /main-wrap -->
</div><!-- /page-home -->

<!-- ══ NEWS (alle) ══ -->
<div class="page" id="page-news">
  <div class="main-wrap">
    <div class="breadcrumb"><a onclick="showPage('home')">Home</a><span class="sep">/</span>News</div>
    <div class="section-head">
      <div class="section-tag">Berichte</div>
      <h2>Alle Neuigkeiten</h2>
    </div>
    <div class="news-grid" id="allNewsGrid"></div>
  </div>
</div>

<!-- ══ ARTIKEL ══ -->
<div class="page" id="page-article">
  <div class="article-hero" id="articleHero">
    <div id="articleImgPh" style="display:none"></div>
    <div class="article-hero-txt"><h1 id="articleTitle"></h1></div>
  </div>
  <div class="main-wrap">
    <div class="article-content">
      <button class="back-btn" onclick="showPage('home')">← Zurück</button>
      <div class="article-body" id="articleBody"></div>
    </div>
  </div>
</div>

<!-- ══ DER VEREIN ══ -->
<div class="page" id="page-verein">
  <div class="main-wrap">
    <div class="breadcrumb"><a onclick="showPage('home')">Home</a><span class="sep">/</span>Der Verein</div>
    <div class="section-head"><div class="section-tag">Über uns</div><h2>Der Schwimmverein Hockenheim</h2></div>
    <div class="white-card" style="margin-bottom:32px">
      <p style="font-size:15px;line-height:1.85;color:var(--text2);margin-bottom:16px">Der Schwimmverein Hockenheim e.V. wurde am 16.06.1967 mit 31 Mitgliedern gegründet. Zum heutigen Zeitpunkt zählen wir über 330 Mitglieder.</p>
      <p style="font-size:15px;line-height:1.85;color:var(--text2);margin-bottom:16px">In der Zwischenzeit konnten Schwimmer/innen des Schwimmvereins beachtliche Platzierungen und Meistertitel bei Kreis-, Bezirks-, Badischen Jahrgangs-, Baden-Württembergischen und Deutschen Master-Meisterschaften erzielen.</p>
      <p style="font-size:15px;line-height:1.85;color:var(--text2);margin-bottom:16px">Der SVH ist heute in der Lage, für verschiedene Trainingsgruppen ein Training im Aquadrom und/oder im Lehrschwimmbecken anzubieten. Daneben bieten wir für interessierte Kinder ab dem Grundschulalter auch Kurse im Anfänger- und Fortgeschrittenenbereich an.</p>
      <p style="font-size:15px;line-height:1.85;color:var(--text2)">Der Verein ist Mitglied im <strong style="color:var(--text)">Badischen Schwimm-Verband e.V. (BSV)</strong> und im <strong style="color:var(--text)">Deutschen Schwimm-Verband e.V. (DSV)</strong>.</p>
    </div>
    <div class="wk-cards" style="margin-top:32px">
      <div class="wk-card" onclick="showPage('vorstandschaft')"><div class="wk-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="var(--blue2)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg></div><h3>Die Vorstandschaft</h3></div>
      <div class="wk-card" onclick="showPage('historie')"><div class="wk-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="var(--blue2)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div><h3>Historie</h3></div>
      <div class="wk-card" onclick="showPage('termine')"><div class="wk-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="var(--blue2)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div><h3>Termine</h3></div>
      <div class="wk-card" onclick="showPage('beitragsordnung')"><div class="wk-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="var(--blue2)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></div><h3>Beitragsordnung</h3></div>
    </div>
  </div>
</div>

<!-- ══ VORSTANDSCHAFT ══ -->
<div class="page" id="page-vorstandschaft">
  <div class="main-wrap">
    <div class="breadcrumb"><a onclick="showPage('home')">Home</a><span class="sep">/</span><a onclick="showPage('verein')">Der Verein</a><span class="sep">/</span>Vorstandschaft</div>
    <div class="section-head"><div class="section-tag">Führung</div><h2>Die Vorstandschaft</h2></div>
    <div class="badge">Geschäftsführender Vorstand</div>
    <div class="person-grid" id="pgVorstand"></div>
    <div class="badge" style="margin-top:24px">Erweiterte Vorstandschaft</div>
    <div class="person-grid" id="pgErweiterter"></div>
  </div>
</div>

<!-- ══ HISTORIE ══ -->
<div class="page" id="page-historie">
  <div class="main-wrap">
    <div class="breadcrumb"><a onclick="showPage('home')">Home</a><span class="sep">/</span><a onclick="showPage('verein')">Der Verein</a><span class="sep">/</span>Historie</div>
    <div class="section-head"><div class="section-tag">Geschichte</div><h2>1. Vorstände seit Gründung 1967</h2></div>
    <div class="white-card" style="max-width:600px">
      <table class="styled-table">
        <tr><th>Zeitraum</th><th>Name</th></tr>
        <tr><td>1967–1971</td><td>Eduard Cermak</td></tr>
        <tr><td>1971–1981</td><td>Gerhard Lebing</td></tr>
        <tr><td>1981–1987</td><td>Peter Knauber</td></tr>
        <tr><td>1987–1991</td><td>Werner Tatomir</td></tr>
        <tr><td>1991–1998</td><td>Hans Brandenburger</td></tr>
        <tr><td>1998–2004</td><td>Roland Sawa</td></tr>
        <tr><td>2004–2012</td><td>Hans Brandenburger</td></tr>
        <tr><td>2012–2024</td><td>Sven Grundner</td></tr>
        <tr><td>2024–heute</td><td><strong>Ramona Brenner</strong></td></tr>
      </table>
    </div>
  </div>
</div>

<!-- ══ TERMINE ══ -->
<div class="page" id="page-termine">
  <div class="main-wrap">
    <div class="breadcrumb"><a onclick="showPage('home')">Home</a><span class="sep">/</span>Termine</div>
    <div class="section-head"><div class="section-tag">Kalender</div><h2>Termine 2026</h2></div>
    <div class="event-list">
      <div class="event-item"><div class="event-date"><div class="event-day">6</div><div class="event-mon">Apr</div></div><div class="event-img-box"><div class="img-ph" style="font-size:10px"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg></div></div><div class="event-info"><h4>Trainingslager</h4><p>06.04.2026 – 10.04.2026 in Hockenheim</p></div></div>
      <div class="event-item"><div class="event-date"><div class="event-day">18</div><div class="event-mon">Apr</div></div><div class="event-img-box"><div class="img-ph" style="font-size:10px"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg></div></div><div class="event-info"><h4>Jahreshauptversammlung</h4><p>15:30 Uhr · Musiksaal Hartmann-Baumann-Schule, Schubertstraße 17</p></div></div>
      <div class="event-item"><div class="event-date"><div class="event-day">19</div><div class="event-mon">Jun</div></div><div class="event-img-box"><div class="img-ph" style="font-size:10px"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg></div></div><div class="event-info"><h4>Zeltlager</h4><p>19.06.2026 – 21.06.2026 am Erlichsee</p></div></div>
      <div class="event-item"><div class="event-date"><div class="event-day">3</div><div class="event-mon">Okt</div></div><div class="event-img-box"><div class="img-ph" style="font-size:10px"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg></div></div><div class="event-info"><h4>Wandertag</h4><p>3. Oktober 2026</p></div></div>
    </div>
  </div>
</div>

<!-- ══ BEITRAGSORDNUNG ══ -->
<div class="page" id="page-beitragsordnung">
  <div class="main-wrap">
    <div class="breadcrumb"><a onclick="showPage('home')">Home</a><span class="sep">/</span><a onclick="showPage('verein')">Der Verein</a><span class="sep">/</span>Beitragsordnung</div>
    <div class="section-head"><div class="section-tag">Mitgliedschaft</div><h2>Beitragsordnung</h2><p>Gültig ab 01. Januar 2022</p></div>
    <div class="white-card" style="max-width:680px">
      <table class="styled-table" style="margin-bottom:24px">
        <tr><th>Kategorie</th><th>Jahresbeitrag</th></tr>
        <tr><td>Passives Mitglied</td><td><strong>€ 60,–</strong></td></tr>
        <tr><td>Jugendliche Aktive bis 25 Jahre</td><td><strong>€ 70,–</strong></td></tr>
        <tr><td>Erwachsene Aktive</td><td><strong>€ 80,–</strong></td></tr>
        <tr><td>Familienmitgliedschaft (Grundbeitrag)</td><td><strong>€ 130,–</strong></td></tr>
        <tr><td>Pro Aktives Familienmitglied</td><td><strong>€ 10,–</strong></td></tr>
        <tr><td>Ehrenmitglieder</td><td><strong>frei</strong></td></tr>
      </table>
      <p style="font-size:13px;color:var(--text2);margin-bottom:12px"><strong style="color:var(--text)">Aufnahmegebühr:</strong> € 25 (einmalig)</p>
      <p style="font-size:13px;color:var(--text2);margin-bottom:12px"><strong style="color:var(--text)">Vereinskonto:</strong> Sparkasse Heidelberg · IBAN: DE66 6725 0020 0006 2064 33 · BIC: SOLADES1HDB</p>
    </div>
  </div>
</div>

<!-- ══ JUGENDORDNUNG ══ -->
<div class="page" id="page-jugendordnung">
  <div class="main-wrap">
    <div class="breadcrumb"><a onclick="showPage('home')">Home</a><span class="sep">/</span>Jugendordnung</div>
    <div class="section-head"><div class="section-tag">Satzung</div><h2>Jugendordnung</h2><p>Gültig ab 01. Januar 2020</p></div>
    <div class="white-card" style="font-size:15px;line-height:1.85;color:var(--text2)">
      <p style="margin-bottom:16px"><strong style="color:var(--text)">§ 1 Zuständigkeit:</strong> Die Jugendabteilung umfasst alle Mitglieder bis zum vollendeten 18. Lebensjahr sowie gewählte Mitarbeiter.</p>
      <p style="margin-bottom:16px"><strong style="color:var(--text)">§ 2 Ziele:</strong> Förderung der sportlichen Betätigung, des sozialen Verhaltens und des Gemeinschaftssinns.</p>
      <p style="margin-bottom:16px"><strong style="color:var(--text)">§ 3 Aufgaben:</strong> Förderung des Schwimmens · Durchführung von Wettkämpfen · Planung von Freizeiten und Zeltlagern</p>
      <p><strong style="color:var(--text)">§ 5 Jugendvollversammlung:</strong> Das oberste Organ der Jugendabteilung. Stimmberechtigt ab vollendetem 7. Lebensjahr. Tritt alle zwei Jahre zusammen.</p>
    </div>
  </div>
</div>

<!-- ══ TRAINING ══ -->
<div class="page" id="page-training">
  <div class="main-wrap">
    <div class="section-head"><div class="section-tag">Sport</div><h2>Training</h2></div>
    <div class="wk-cards">
      <div class="wk-card" onclick="showPage('jugend')"><div class="wk-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="var(--blue2)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg></div><h3>Jugend</h3><p>6–20 Jahre · Technik & Wettkampf</p></div>
