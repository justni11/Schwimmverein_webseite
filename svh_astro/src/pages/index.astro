        <div style="display:flex;gap:10px;align-items:center">
          <button class="btn-primary" style="font-size:13px;padding:10px 22px" onclick="saveGithubSettings()">💾 Einstellungen speichern</button>
          <button onclick="testGithubConnection()" style="background:rgba(55,160,38,.15);border:1px solid var(--border);color:var(--accent);padding:10px 18px;border-radius:50px;font-size:13px;font-weight:600;cursor:pointer;font-family:Inter,sans-serif">🔗 Verbindung testen</button>
          <button onclick="clearGithubSettings()" style="background:none;border:none;color:var(--muted);font-size:12px;cursor:pointer;font-family:Inter,sans-serif">Einstellungen löschen</button>
        </div>
      </div>

      <!-- Hinweise -->
      <div class="white-card" style="max-width:680px">
        <h3 style="font-size:18px;font-weight:700;color:var(--text);margin-bottom:16px">ℹ️ Hinweise</h3>
        <p style="font-size:14px;color:var(--text2);line-height:1.8;margin-bottom:12px">Texte, Artikel und Einstellungen werden im <strong style="color:var(--text)">Browser-Speicher (localStorage)</strong> gespeichert – Bilder nach GitHub Verbindung direkt ins Repository.</p>
        <p style="font-size:14px;color:var(--text2);line-height:1.8;margin-bottom:24px">Für die finale Produktionsseite empfiehlt sich eine Backend-Lösung (TYPO3, Node.js API).</p>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <button class="btn-del" onclick="if(confirm('Alle eigenen Artikel löschen?')){clearCustomArticles()}">Artikel löschen</button>
          <button class="btn-del" onclick="if(confirm('Alle Ordner löschen?')){clearFolders()}">Ordner löschen</button>
          <button class="btn-del" onclick="if(confirm('Alle gespeicherten Daten zurücksetzen?')){resetAll()}">Alles zurücksetzen</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ══ FOOTER ══ -->


<!-- ── CROP / RESIZE MODAL ── -->
<div id="cropModal">
  <div style="font-size:14px;color:rgba(255,255,255,.8);text-align:center;margin-bottom:8px">Bild zuschneiden – Bereich auswählen und <strong>Zuschneiden</strong> klicken</div>
  <div class="crop-container">
    <canvas id="cropCanvas"></canvas>
    <canvas id="cropSelection" style="position:absolute;inset:0;pointer-events:none"></canvas>
  </div>
  <div class="crop-hint">Klicken und ziehen um einen Bereich zu wählen · Ohne Auswahl = Original verwenden</div>
  <div class="crop-controls">
    <button class="crop-btn primary" onclick="cropConfirm()">✂ Zuschneiden & verwenden</button>
    <button class="crop-btn secondary" onclick="cropUseOriginal()">Ohne Zuschnitt verwenden</button>
    <button class="crop-btn danger" onclick="cropCancel()">Abbrechen</button>
  </div>
</div>

<!-- Admin Login Modal -->
<div class="overlay" id="loginOverlay">
  <div class="overlay-card">
    <h2>Admin Login</h2>
    <p>Bitte gib das Admin-Passwort ein um fortzufahren.</p>
    <div class="form-field">
      <label>Passwort</label>
      <input type="password" id="pwInput" placeholder="••••••••" onkeydown="if(event.key==='Enter')checkLogin()"/>
      <div class="form-error" id="pwError" style="display:none">Falsches Passwort. Bitte erneut versuchen.</div>
    </div>
    <button class="btn-submit" onclick="checkLogin()">Einloggen</button>
    <button class="btn-cancel" onclick="closeAdminLogin()">Abbrechen</button>
  </div>
</div>

<div id="uploadHint">✓ Bild eingefügt!</div>
</Layout>
