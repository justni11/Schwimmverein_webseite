---
// src/layouts/Layout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
}
const { title = 'SV Hockenheim e.V.' } = Astro.props;
const base = '/Schwimmverein_webseite';
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0,minimum-scale=1.0,maximum-scale=5.0,viewport-fit=cover"/>
  <title>{title} – SV Hockenheim e.V.</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href={`${base}/styles/global.css`}/>
</head>
<body>

<Header />

<!-- Mobile Drawer (für alle Seiten) -->
<div class="mobile-drawer" id="mobileDrawer">
  <div class="mob-item"><div class="mob-top" onclick="if(typeof mobNav!=='undefined'){mobNav('home')}else{location.href='/Schwimmverein_webseite/';closeMobileMenu()}">Home</div></div>
  <div class="mob-item">
    <div class="mob-top" onclick="toggleMobSub('msub-news')">News <span class="arr">▾</span></div>
    <div class="mob-sub" id="msub-news">
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('news')}else{location.href='/Schwimmverein_webseite/';closeMobileMenu()}">Alle Berichte</a>
      <a onclick="if(typeof mobArticle!=='undefined'){mobArticle('dossenheim2026')}else{location.href='/Schwimmverein_webseite/';closeMobileMenu()}">Dossenheim 2026</a>
      <a onclick="if(typeof mobArticle!=='undefined'){mobArticle('hoggicup2026')}else{location.href='/Schwimmverein_webseite/';closeMobileMenu()}">Hoggi Cup 2026</a>
      <a onclick="if(typeof mobArticle!=='undefined'){mobArticle('heddesheim2026')}else{location.href='/Schwimmverein_webseite/';closeMobileMenu()}">Heddesheim 2026</a>
      <a onclick="if(typeof mobArticle!=='undefined'){mobArticle('bruehlmasters2026')}else{location.href='/Schwimmverein_webseite/';closeMobileMenu()}">Masters Brühl 2026</a>
      <a onclick="if(typeof mobArticle!=='undefined'){mobArticle('vereinsfeier2025')}else{location.href='/Schwimmverein_webseite/';closeMobileMenu()}">Vereinsfeier 2025</a>
      <a onclick="if(typeof mobArticle!=='undefined'){mobArticle('neptuncup2025')}else{location.href='/Schwimmverein_webseite/';closeMobileMenu()}">Neptun Cup 2025</a>
    </div>
  </div>
  <div class="mob-item">
    <div class="mob-top" onclick="toggleMobSub('msub-verein')">Der Verein <span class="arr">▾</span></div>
    <div class="mob-sub" id="msub-verein">
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('vorstandschaft')}else{location.href='/Schwimmverein_webseite/vorstandschaft';closeMobileMenu()}">Die Vorstandschaft</a>
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('historie')}else{location.href='/Schwimmverein_webseite/historie';closeMobileMenu()}">Historie</a>
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('termine')}else{location.href='/Schwimmverein_webseite/termine';closeMobileMenu()}">Termine</a>
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('beitragsordnung')}else{location.href='/Schwimmverein_webseite/beitragsordnung';closeMobileMenu()}">Beitragsordnung</a>
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('jugendordnung')}else{location.href='/Schwimmverein_webseite/jugendordnung';closeMobileMenu()}">Jugendordnung</a>
    </div>
  </div>
  <div class="mob-item">
    <div class="mob-top" onclick="toggleMobSub('msub-training')">Training <span class="arr">▾</span></div>
    <div class="mob-sub" id="msub-training">
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('jugend')}else{location.href='/Schwimmverein_webseite/jugend';closeMobileMenu()}">Jugend</a>
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('masters')}else{location.href='/Schwimmverein_webseite/masters';closeMobileMenu()}">Masters</a>
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('trainingszeiten')}else{location.href='/Schwimmverein_webseite/trainingszeiten';closeMobileMenu()}">Trainingszeiten</a>
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('trainer')}else{location.href='/Schwimmverein_webseite/trainer';closeMobileMenu()}">Unsere Trainer</a>
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('trainingsstaetten')}else{location.href='/Schwimmverein_webseite/trainingsstaetten';closeMobileMenu()}">Trainingsstätten</a>
    </div>
  </div>
  <div class="mob-item">
    <div class="mob-top" onclick="toggleMobSub('msub-kurse')">Schwimmkurse <span class="arr">▾</span></div>
    <div class="mob-sub" id="msub-kurse">
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('kurse')}else{location.href='/Schwimmverein_webseite/kurse';closeMobileMenu()}">Informationen</a>
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('kurstrainer')}else{location.href='/Schwimmverein_webseite/kurstrainer';closeMobileMenu()}">Kurstrainer</a>
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('einzelstunden')}else{location.href='/Schwimmverein_webseite/einzelstunden';closeMobileMenu()}">Einzelstunden</a>
    </div>
  </div>
  <div class="mob-item"><div class="mob-top" onclick="if(typeof mobNav!=='undefined'){mobNav('wettkampf')}else{location.href='/Schwimmverein_webseite/wettkampf';closeMobileMenu()}">Wettkampf</div></div>
  <div class="mob-item">
    <div class="mob-top" onclick="toggleMobSub('msub-sonst')">Sonstiges <span class="arr">▾</span></div>
    <div class="mob-sub" id="msub-sonst">
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('datenschutz')}else{location.href='/Schwimmverein_webseite/datenschutz';closeMobileMenu()}">Datenschutz</a>
      <a onclick="if(typeof mobNav!=='undefined'){mobNav('impressum')}else{location.href='/Schwimmverein_webseite/impressum';closeMobileMenu()}">Impressum</a>
      <a onclick="closeMobileMenu();if(typeof openAdminLogin!=='undefined')openAdminLogin()" style="color:rgba(255,255,255,.4);font-size:12px">⚙ Admin Panel</a>
    </div>
  </div>
</div>

<main>
  <slot />
</main>

<Footer />

<!-- Globale Modals (werden von JS benötigt) -->
<div id="cropModal">
  <div style="font-size:14px;color:rgba(255,255,255,.8);text-align:center;margin-bottom:8px">
    Bild zuschneiden – Bereich wählen und <strong>Zuschneiden</strong> klicken
  </div>
  <div class="crop-container">
    <canvas id="cropCanvas"></canvas>
    <canvas id="cropSelection" style="position:absolute;inset:0;pointer-events:none"></canvas>
  </div>
  <div class="crop-hint">Klicken und ziehen · Ohne Auswahl = Original</div>
  <div class="crop-controls">
    <button class="crop-btn primary" onclick="cropConfirm()">✂ Zuschneiden &amp; verwenden</button>
    <button class="crop-btn secondary" onclick="cropUseOriginal()">Ohne Zuschnitt</button>
    <button class="crop-btn danger" onclick="cropCancel()">Abbrechen</button>
  </div>
</div>

<div class="overlay" id="loginOverlay">
  <div class="overlay-card">
    <h2>Admin Login</h2>
    <p>Bitte Admin-Passwort eingeben.</p>
    <div class="form-field">
      <label>Passwort</label>
      <input type="password" id="pwInput" placeholder="••••••••"/>
      <div class="form-error" id="pwError" style="display:none">Falsches Passwort.</div>
    </div>
    <button class="btn-submit" onclick="checkLogin()">Einloggen</button>
    <button class="btn-cancel" onclick="closeAdminLogin()">Abbrechen</button>
  </div>
</div>

<div id="uploadHint">✓ Bild gespeichert!</div>

<!-- Scripts – Reihenfolge wichtig! -->
<script is:inline src={`${base}/scripts/content.js`}></script>
<script is:inline src={`${base}/scripts/carousel.js`}></script>
<script is:inline src={`${base}/scripts/navigation.js`}></script>
<script is:inline src={`${base}/scripts/admin-tools.js`}></script>
<script is:inline src={`${base}/scripts/main.js`}></script>

</body>
</html>
